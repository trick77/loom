# syntax=docker/dockerfile:1

# --- Stage 1: build the Go API binary (pure-Go, no cgo) ---
FROM golang:1.25-alpine AS build
ARG BACKEND_VERSION=dev
WORKDIR /app/backend
COPY backend/go.mod backend/go.sum ./
RUN go mod download
COPY backend/ ./
RUN CGO_ENABLED=0 go build -ldflags="-s -w -X main.version=${BACKEND_VERSION}" -o /out/loom ./cmd/loom

# --- Stage 2: minimal runtime ---
FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/loom /loom
EXPOSE 8080
ENTRYPOINT ["/loom"]
