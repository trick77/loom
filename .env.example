SLOP_SESSION_SECRET=change-me-to-a-long-random-string
SLOP_PUBLIC_URL=https://slop.example.com
SLOP_AUTH_MODE=oidc
SLOP_OIDC_ISSUER=https://auth.example.com/application/o/slop/
SLOP_OIDC_CLIENT_ID=
SLOP_OIDC_CLIENT_SECRET=
SLOP_OIDC_REDIRECT_URL=https://slop.example.com/api/auth/callback
SLOP_OIDC_POST_LOGOUT_REDIRECT_URL=https://slop.example.com/
SLOP_OIDC_ADMIN_GROUP=slop-admins
SLOP_CHAT_BASE_URL=http://your-mimo-host/v1
SLOP_CHAT_API_KEY=
SLOP_CHAT_MODEL=MiMo
SLOP_CHAT_REASONING_EFFORT=high
SLOP_EMBED_BASE_URL=https://api.openai.com/v1
SLOP_EMBED_API_KEY=sk-...
SLOP_EMBED_MODEL=text-embedding-3-small
# Image generation (optional). Default model is FLUX.2 [klein] 4B.
SLOP_BFL_BASE_URL=https://api.bfl.ai/v1
SLOP_BFL_API_KEY=
SLOP_BFL_MODEL=flux-2-klein-4b
SLOP_BFL_POLL_TIMEOUT=1m
# Built-in Tavily web search (opt-in): set the API key to enable it. Never commit a real key.
SLOP_TAVILY_URL=https://mcp.tavily.com/mcp/
SLOP_TAVILY_API_KEY=
SLOP_CONTEXT7_API_KEY=
SLOP_CONTEXT7_MCP_URL=https://mcp.context7.com/mcp
SLOP_MCP_CONFIG=/config/mcp.json

# Local development without OIDC:
# SLOP_AUTH_MODE=dev
# SLOP_ADDR=127.0.0.1:8080
# SLOP_PUBLIC_URL=http://localhost:8080
