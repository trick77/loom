# Public URL and session secret
BACKEND_PUBLIC_URL=https://loom.example.com
BACKEND_SESSION_SECRET=change-me-to-a-long-random-string

# Authentication
BACKEND_AUTH_MODE=oidc
BACKEND_OIDC_ISSUER=https://auth.example.com/application/o/loom/
BACKEND_OIDC_CLIENT_ID=
BACKEND_OIDC_CLIENT_SECRET=
BACKEND_OIDC_REDIRECT_URL=https://loom.example.com/api/auth/callback
BACKEND_OIDC_POST_LOGOUT_REDIRECT_URL=https://loom.example.com/
BACKEND_OIDC_ADMIN_GROUP=loom-admins

# Chat model
BACKEND_CHAT_BASE_URL=http://your-mimo-host/v1
BACKEND_CHAT_API_KEY=
# Model and reasoning effort are hardcoded to MiMo (mimo-v2.5-pro for text,
# mimo-v2.5 for image turns, reasoning_effort=high) and are not configurable.
BACKEND_CHAT_MAX_COMPLETION_TOKENS=2048
BACKEND_CHAT_TIMEOUT=2m
# Abort a chat stream that goes silent mid-turn after this idle window (0 disables).
# Far below BACKEND_CHAT_TIMEOUT so a stalled model ends in seconds, not minutes.
BACKEND_CHAT_IDLE_TIMEOUT=60s

# Embeddings
BACKEND_EMBED_BASE_URL=https://api.openai.com/v1
BACKEND_EMBED_API_KEY=sk-...
BACKEND_EMBED_MODEL=text-embedding-3-small

# Image generation
BACKEND_BFL_BASE_URL=https://api.bfl.ai/v1
BACKEND_BFL_API_KEY=
BACKEND_BFL_MODEL=flux-2-klein-4b
BACKEND_BFL_POLL_TIMEOUT=1m

# Tavily web search
BACKEND_TAVILY_URL=https://mcp.tavily.com/mcp/
BACKEND_TAVILY_API_KEY=

# MCP sidecars
BACKEND_CONTEXT7_API_KEY=
BACKEND_CONTEXT7_MCP_URL=https://mcp.context7.com/mcp
BACKEND_FETCH_MCP_URL=http://fetch:8090/mcp
BACKEND_OBSCURA_MCP_URL=http://obscura:8090/mcp

# Log verbosity: debug | info | warn | error (default info).
# BACKEND_LOG_LEVEL=info

# Local development without OIDC:
# BACKEND_AUTH_MODE=dev
# BACKEND_ADDR=127.0.0.1:8080
# BACKEND_PUBLIC_URL=http://localhost:8080
