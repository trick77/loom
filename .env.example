SLOPR_SESSION_SECRET=change-me-to-a-long-random-string
SLOPR_IMAGE=ghcr.io/trick77/slopr:latest
SLOPR_FETCH_IMAGE=ghcr.io/trick77/slopr-fetch:latest
SLOPR_OBSCURA_IMAGE=ghcr.io/trick77/slopr-obscura:latest
SLOPR_PUBLIC_URL=https://slopr.example.com
SLOPR_AUTH_MODE=oidc
SLOPR_OIDC_ISSUER=https://auth.example.com/application/o/slopr/
SLOPR_OIDC_CLIENT_ID=
SLOPR_OIDC_CLIENT_SECRET=
SLOPR_OIDC_REDIRECT_URL=https://slopr.example.com/api/auth/callback
SLOPR_OIDC_POST_LOGOUT_REDIRECT_URL=https://slopr.example.com/
SLOPR_OIDC_ADMIN_GROUP=slopr-admins
SLOPR_CHAT_BASE_URL=http://your-mimo-host/v1
SLOPR_CHAT_API_KEY=
SLOPR_CHAT_MODEL=MiMo
SLOPR_CHAT_REASONING_EFFORT=high
SLOPR_EMBED_BASE_URL=https://api.openai.com/v1
SLOPR_EMBED_API_KEY=sk-...
SLOPR_EMBED_MODEL=text-embedding-3-small
# Image generation (optional). Default model is FLUX.2 [klein] 4B.
SLOPR_BFL_BASE_URL=https://api.bfl.ai/v1
SLOPR_BFL_API_KEY=
SLOPR_BFL_MODEL=flux-2-klein-4b
SLOPR_BFL_POLL_TIMEOUT=1m
# Built-in Tavily web search (opt-in): set the API key to enable it. Never commit a real key.
SLOPR_TAVILY_URL=https://mcp.tavily.com/mcp/
SLOPR_TAVILY_API_KEY=
SLOPR_CONTEXT7_API_KEY=
SLOPR_CONTEXT7_MCP_URL=https://mcp.context7.com/mcp
SLOPR_FETCH_MCP_URL=http://fetch:8090/mcp
SLOPR_OBSCURA_MCP_URL=http://obscura:8090/mcp

# Local development without OIDC:
# SLOPR_AUTH_MODE=dev
# SLOPR_ADDR=127.0.0.1:8080
# SLOPR_PUBLIC_URL=http://localhost:8080
